---
import team from "@/data/core_team.json";

interface Member {
  name: string;
  role: string;
  linkedin: string;
  photo: string;
  member_since: string;
  hosted_events: number;
  joined_events: number;
}

const sorted = [...(team as Member[])].sort((a, b) => {
  const scoreA = a.hosted_events * 5 + a.joined_events;
  const scoreB = b.hosted_events * 5 + b.joined_events;
  return scoreB - scoreA;
});

function formatMemberSince(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}
---

<section id="team" class="bg-brand-900 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-4 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Core Team
    </div>
    <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      The people behind the community
    </h2>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        sorted.map((member) => {
          const score = member.hosted_events * 5 + member.joined_events;
          return (
            <div class="flex flex-col items-center rounded-xl border border-brand-700 bg-brand-800/40 p-6 text-center">
              <div class="h-24 w-24 overflow-hidden rounded-full bg-brand-600">
                {member.photo && (
                  <img
                    src={member.photo}
                    alt={member.name}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                )}
              </div>

              <h3 class="mt-4 font-display text-lg font-semibold text-white">{member.name}</h3>
              <p class="mt-1 text-sm text-brand-300">{member.role}</p>

              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 text-brand-400 transition hover:text-accent-500"
                aria-label={`${member.name} on LinkedIn`}
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>

              <div class="mt-4 w-full border-t border-brand-700 pt-4">
                <p class="text-2xl font-bold text-accent-500">{score}</p>
                <p class="text-xs text-brand-400">participation score</p>
                <p class="mt-2 text-xs text-brand-400">
                  Member since {formatMemberSince(member.member_since)}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href="/leaderboard"
        class="inline-flex items-center gap-2 text-sm font-medium text-accent-400 transition hover:text-accent-300"
      >
        See full top 100 leaderboard
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
