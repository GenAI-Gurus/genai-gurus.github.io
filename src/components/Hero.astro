---
import site from "@/data/site.json";
import stats from "@/data/community_stats.json";
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-28">
  <!-- Ambient glow effects -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-20 left-1/4 h-96 w-96 rounded-full bg-accent-500/8 blur-3xl animate-glow-pulse"></div>
    <div class="absolute top-40 right-1/4 h-72 w-72 rounded-full bg-accent-400/5 blur-3xl animate-glow-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-20 left-1/2 h-64 w-[40rem] -translate-x-1/2 rounded-full bg-brand-700/30 blur-3xl"></div>
  </div>

  <!-- Subtle grid -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <!-- Badge -->
    <div class="animate-fade-in mb-8 inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-1.5 text-sm font-medium text-accent-400">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-500"></span>
      </span>
      Community of {stats.meetup_members.toLocaleString()}+ AI practitioners
    </div>

    <h1
      class="animate-fade-in-up font-display text-4xl leading-tight font-extrabold tracking-tight text-white sm:text-5xl md:text-6xl md:leading-tight"
    >
      Where AI practitioners<br/>
      <span class="bg-gradient-to-r from-accent-500 to-accent-300 bg-clip-text text-transparent">go deeper</span>
    </h1>

    <p class="animate-fade-in-up mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-200 md:text-xl" style="animation-delay: 0.15s;">
      A global community for builders, researchers, and leaders exploring applied
      Generative AI through practical talks, open discussion, and responsible innovation.
    </p>

    <div class="animate-fade-in-up mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" style="animation-delay: 0.3s;">
      <a
        href={site.links.meetup}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 rounded-xl bg-accent-500 px-7 py-3.5 text-base font-semibold text-brand-950 shadow-lg shadow-accent-500/25 transition-all hover:bg-accent-400 hover:shadow-accent-500/40 hover:-translate-y-0.5"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.71 14.07a2.97 2.97 0 0 0-.85-1.07 2.97 2.97 0 0 0 .6-1.72c0-1.6-1.28-2.9-2.87-2.9a2.88 2.88 0 0 0-2.71 1.93 2.88 2.88 0 0 0-2.56-1.56c-1.3 0-2.4.86-2.75 2.05a2.88 2.88 0 0 0-2.34-1.2c-1.59 0-2.88 1.3-2.88 2.9 0 .54.15 1.05.41 1.48A2.9 2.9 0 0 0 2 16.86c0 1.3.86 2.4 2.04 2.76a2.87 2.87 0 0 0 4.98.65 2.87 2.87 0 0 0 4.17-.42c.57.67 1.42 1.1 2.37 1.1a2.88 2.88 0 0 0 2.74-3.76c.7-.5 1.17-1.32 1.17-2.25 0-.33-.06-.65-.17-.94l.01.07z"></path>
        </svg>
        Join next event on Meetup
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>

      <div class="flex gap-3">
        <a
          href={site.links.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-brand-600/80 bg-brand-800/30 px-5 py-3.5 text-sm font-medium text-brand-200 backdrop-blur-sm transition-all hover:border-brand-400 hover:bg-brand-800/50 hover:text-white hover:-translate-y-0.5"
          aria-label="Follow on LinkedIn"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
          </svg>
          LinkedIn
        </a>

        <a
          href={site.links.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-brand-600/80 bg-brand-800/30 px-5 py-3.5 text-sm font-medium text-brand-200 backdrop-blur-sm transition-all hover:border-brand-400 hover:bg-brand-800/50 hover:text-white hover:-translate-y-0.5"
          aria-label="Watch on YouTube"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
          </svg>
          YouTube
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="animate-fade-in-up mt-20 grid grid-cols-2 gap-8 md:grid-cols-4" style="animation-delay: 0.45s;">
      <div class="group relative">
        <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-accent-500/5 to-transparent opacity-0 transition group-hover:opacity-100"></div>
        <div class="relative rounded-xl border border-brand-700/50 bg-brand-800/20 px-4 py-5 backdrop-blur-sm transition group-hover:border-accent-500/20">
          <p class="font-display text-2xl font-bold text-white md:text-3xl">{stats.meetup_members.toLocaleString()}+</p>
          <p class="mt-1 text-sm text-brand-400">Meetup members</p>
        </div>
      </div>
      <div class="group relative">
        <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-accent-500/5 to-transparent opacity-0 transition group-hover:opacity-100"></div>
        <div class="relative rounded-xl border border-brand-700/50 bg-brand-800/20 px-4 py-5 backdrop-blur-sm transition group-hover:border-accent-500/20">
          <p class="font-display text-2xl font-bold text-white md:text-3xl">{stats.total_events}+</p>
          <p class="mt-1 text-sm text-brand-400">Events hosted</p>
        </div>
      </div>
      <div class="group relative">
        <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-accent-500/5 to-transparent opacity-0 transition group-hover:opacity-100"></div>
        <div class="relative rounded-xl border border-brand-700/50 bg-brand-800/20 px-4 py-5 backdrop-blur-sm transition group-hover:border-accent-500/20">
          <p class="font-display text-2xl font-bold text-white md:text-3xl">{stats.total_reach.toLocaleString()}+</p>
          <p class="mt-1 text-sm text-brand-400">Total audience</p>
        </div>
      </div>
      <div class="group relative">
        <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-accent-500/5 to-transparent opacity-0 transition group-hover:opacity-100"></div>
        <div class="relative rounded-xl border border-brand-700/50 bg-brand-800/20 px-4 py-5 backdrop-blur-sm transition group-hover:border-accent-500/20">
          <p class="font-display text-2xl font-bold text-white md:text-3xl">Since 2023</p>
          <p class="mt-1 text-sm text-brand-400">Active community</p>
        </div>
      </div>
    </div>
  </div>
</section>
