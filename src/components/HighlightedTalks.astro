---
import site from "@/data/site.json";
import talks from "@/data/featured_talks.json";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}
---

<section id="talks" class="relative py-20 md:py-28">
  <div class="pointer-events-none absolute right-0 top-0 h-96 w-96 rounded-full bg-accent-500/3 blur-3xl"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Featured Talks
    </div>
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          Selected sessions from our community
        </h2>
        <p class="mt-3 max-w-2xl text-brand-300">
          Curated highlights from past events — real talks, real depth, real practitioners.
        </p>
      </div>
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 self-start rounded-lg border border-brand-600/60 px-4 py-2 text-sm font-medium text-brand-300 transition hover:border-brand-400 hover:text-white md:self-auto"
      >
        View all on YouTube
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        talks.map((talk) => {
          const totalReach = talk.meetup_participants + talk.youtube_views;
          return (
            <article class="group flex flex-col overflow-hidden rounded-2xl border border-brand-700/50 bg-gradient-to-b from-brand-800/40 to-brand-800/20 shadow-lg shadow-black/10 transition-all hover:border-brand-600/80 hover:shadow-xl hover:shadow-black/20 hover:-translate-y-1">
              <a
                href={talk.youtube_url}
                target="_blank"
                rel="noopener noreferrer"
                class="relative block flex-shrink-0 overflow-hidden"
              >
                <div class="aspect-video w-full bg-brand-700">
                  {talk.image && (
                    <img
                      src={talk.image}
                      alt={talk.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                    <svg class="h-7 w-7 translate-x-0.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </a>

              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-medium text-brand-400">{formatDate(talk.date)}</p>
                <h3 class="mt-2 font-display text-lg font-semibold leading-snug text-white transition group-hover:text-accent-300">
                  {talk.title}
                </h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-brand-300">
                  {talk.summary}
                </p>

                {talk.speaker_name && (
                  <div class="mt-4 flex items-center gap-3">
                    <div class="h-9 w-9 flex-shrink-0 overflow-hidden rounded-full bg-brand-600 ring-2 ring-brand-700">
                      {talk.speaker_photo && (
                        <img
                          src={talk.speaker_photo}
                          alt={talk.speaker_name}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="truncate text-sm font-medium text-white">{talk.speaker_name}</p>
                      {talk.speaker_role && (
                        <p class="truncate text-xs text-brand-400">{talk.speaker_role}</p>
                      )}
                    </div>
                  </div>
                )}

                <div class="mt-auto border-t border-brand-700/50 pt-4 mt-4">
                  <div class="flex items-baseline gap-2">
                    <p class="font-display text-xl font-bold text-accent-500">
                      {totalReach.toLocaleString()}
                    </p>
                    <span class="text-xs font-normal text-brand-400">total reach</span>
                  </div>
                  <div class="mt-1.5 flex gap-4 text-xs text-brand-400">
                    <span class="flex items-center gap-1">
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                      {talk.meetup_participants} attendees
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                      {talk.youtube_views.toLocaleString()} views
                    </span>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
      <a
        href={site.links.meetup}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 14.07a2.97 2.97 0 0 0-.85-1.07 2.97 2.97 0 0 0 .6-1.72c0-1.6-1.28-2.9-2.87-2.9a2.88 2.88 0 0 0-2.71 1.93 2.88 2.88 0 0 0-2.56-1.56c-1.3 0-2.4.86-2.75 2.05a2.88 2.88 0 0 0-2.34-1.2c-1.59 0-2.88 1.3-2.88 2.9 0 .54.15 1.05.41 1.48A2.9 2.9 0 0 0 2 16.86c0 1.3.86 2.4 2.04 2.76a2.87 2.87 0 0 0 4.98.65 2.87 2.87 0 0 0 4.17-.42c.57.67 1.42 1.1 2.37 1.1a2.88 2.88 0 0 0 2.74-3.76c.7-.5 1.17-1.32 1.17-2.25 0-.33-.06-.65-.17-.94l.01.07z"/></svg>
        Join Meetup group
      </a>
      <a
        href={site.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Follow LinkedIn page
      </a>
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Visit YouTube channel
      </a>
    </div>
  </div>
</section>
