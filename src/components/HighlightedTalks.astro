---
import site from "@/data/site.json";
import talks from "@/data/featured_talks.json";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}
---

<section id="talks" class="relative py-20 md:py-28">
  <div class="pointer-events-none absolute right-0 top-0 h-96 w-96 rounded-full bg-accent-500/3 blur-3xl"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Featured Talks
    </div>
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          Selected sessions from our community
        </h2>
        <p class="mt-3 max-w-2xl text-brand-300">
          Curated highlights from past events — real talks, real depth, real practitioners.
        </p>
      </div>
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 self-start rounded-lg border border-brand-600/60 px-4 py-2 text-sm font-medium text-brand-300 transition hover:border-brand-400 hover:text-white md:self-auto"
      >
        View all on YouTube
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        talks.map((talk) => {
          const views = talk.youtube_views ?? 0;
          const totalReach = talk.meetup_participants + views;
          return (
            <article class="group flex flex-col overflow-hidden rounded-2xl border border-brand-700/50 bg-gradient-to-b from-brand-800/40 to-brand-800/20 shadow-lg shadow-black/10 transition-all hover:border-brand-600/80 hover:shadow-xl hover:shadow-black/20 hover:-translate-y-1">
              <a
                href={talk.youtube_url}
                target="_blank"
                rel="noopener noreferrer"
                class="relative block flex-shrink-0 overflow-hidden"
              >
                <div class="aspect-video w-full bg-brand-700">
                  {talk.image && (
                    <img
                      src={talk.image}
                      alt={talk.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                    <svg class="h-7 w-7 translate-x-0.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </a>

              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-medium text-brand-400">{formatDate(talk.date)}</p>
                <h3 class="mt-2 font-display text-lg font-semibold leading-snug text-white transition group-hover:text-accent-300">
                  {talk.title}
                </h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-brand-300">
                  {talk.summary}
                </p>

                {talk.speaker_name && (
                  <div class="mt-4 flex items-center gap-3">
                    <div class="h-9 w-9 flex-shrink-0 overflow-hidden rounded-full bg-brand-600 ring-2 ring-brand-700">
                      {talk.speaker_photo && (
                        <img
                          src={talk.speaker_photo}
                          alt={talk.speaker_name}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="truncate text-sm font-medium text-white">{talk.speaker_name}</p>
                      {talk.speaker_role && (
                        <p class="truncate text-xs text-brand-400">{talk.speaker_role}</p>
                      )}
                    </div>
                  </div>
                )}

                <div class="mt-auto border-t border-brand-700/50 pt-4 mt-4">
                  <div class="flex items-baseline gap-2">
                    <p class="font-display text-xl font-bold text-accent-500">
                      {totalReach.toLocaleString()}
                    </p>
                    <span class="text-xs font-normal text-brand-400">total reach</span>
                  </div>
                  <div class="mt-1.5 flex gap-4 text-xs text-brand-400">
                    <span>{talk.meetup_participants} attendees</span>
                    {views > 0 && <span>{views.toLocaleString()} views</span>}
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
      <a
        href={site.links.meetup}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        Join Meetup group
      </a>
      <a
        href={site.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        Follow LinkedIn page
      </a>
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-brand-600/60 bg-brand-800/20 px-5 py-3 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:bg-brand-800/40 hover:text-white"
      >
        Visit YouTube channel
      </a>
    </div>
  </div>
</section>
