---
import site from "@/data/site.json";
import talks from "@/data/featured_talks.json";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}
---

<section id="talks" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-4 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Featured Talks
    </div>
    <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      Selected sessions from our community
    </h2>
    <p class="mt-4 max-w-2xl text-brand-300">
      Curated highlights from past events — real talks, real depth, real practitioners.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        talks.map((talk) => {
          const totalReach = talk.meetup_participants + talk.youtube_views;
          return (
            <article class="group flex flex-col overflow-hidden rounded-xl border border-brand-700 bg-brand-800/40 transition hover:border-brand-600">
              <a
                href={talk.youtube_url}
                target="_blank"
                rel="noopener noreferrer"
                class="relative block flex-shrink-0 overflow-hidden"
              >
                <div class="aspect-video w-full bg-brand-700">
                  {talk.image && (
                    <img
                      src={talk.image}
                      alt={talk.title}
                      class="h-full w-full object-cover transition group-hover:scale-105"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 transition group-hover:opacity-100">
                  <svg class="h-12 w-12 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </a>

              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-medium text-brand-400">{formatDate(talk.date)}</p>
                <h3 class="mt-2 font-display text-lg font-semibold leading-snug text-white">
                  {talk.title}
                </h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-brand-300">
                  {talk.summary}
                </p>

                {talk.speaker_name && (
                  <div class="mt-4 flex items-center gap-3">
                    <div class="h-8 w-8 flex-shrink-0 overflow-hidden rounded-full bg-brand-600">
                      {talk.speaker_photo && (
                        <img
                          src={talk.speaker_photo}
                          alt={talk.speaker_name}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="truncate text-sm font-medium text-white">{talk.speaker_name}</p>
                      {talk.speaker_role && (
                        <p class="truncate text-xs text-brand-400">{talk.speaker_role}</p>
                      )}
                    </div>
                  </div>
                )}

                <div class="mt-auto border-t border-brand-700 pt-4 mt-4">
                  <p class="text-lg font-bold text-accent-500">
                    {totalReach.toLocaleString()}
                    <span class="text-xs font-normal text-brand-400"> total reach</span>
                  </p>
                  <div class="mt-1 flex gap-4 text-xs text-brand-400">
                    <span>{talk.meetup_participants} attendees</span>
                    <span>{talk.youtube_views.toLocaleString()} views</span>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href={site.links.meetup}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-brand-600 px-5 py-3 text-sm font-medium text-brand-200 transition hover:border-brand-400 hover:text-white"
      >
        Join Meetup group
      </a>
      <a
        href={site.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-brand-600 px-5 py-3 text-sm font-medium text-brand-200 transition hover:border-brand-400 hover:text-white"
      >
        Follow LinkedIn page
      </a>
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-brand-600 px-5 py-3 text-sm font-medium text-brand-200 transition hover:border-brand-400 hover:text-white"
      >
        Visit YouTube channel
      </a>
    </div>
  </div>
</section>
