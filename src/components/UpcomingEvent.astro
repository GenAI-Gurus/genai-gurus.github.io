---
import event from "@/data/upcoming_event.json";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZoneName: "short",
  });
}
---

<section id="upcoming" class="bg-brand-900 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-4 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Next Event
    </div>
    <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      Don't miss our upcoming session
    </h2>

    <div
      class="mt-10 overflow-hidden rounded-2xl border border-brand-700 bg-brand-800/50 md:flex"
    >
      {
        event.image && (
          <div class="flex-shrink-0 md:w-2/5">
            <img
              src={event.image}
              alt={event.title}
              class="h-64 w-full object-cover md:h-full"
              loading="lazy"
            />
          </div>
        )
      }

      <div class="flex flex-1 flex-col justify-center p-8 md:p-10">
        <p class="text-sm font-medium text-accent-400">
          {formatDate(event.date)}
        </p>

        <h3 class="mt-3 font-display text-2xl font-bold leading-snug text-white md:text-3xl">
          {event.title}
        </h3>

        {
          event.speaker_name && (
            <p class="mt-3 text-base text-brand-200">
              <span class="font-semibold text-white">{event.speaker_name}</span>
              {event.speaker_role && (
                <span class="text-brand-300"> &middot; {event.speaker_role}</span>
              )}
            </p>
          )
        }

        <p class="mt-4 leading-relaxed text-brand-300">
          {event.summary}
        </p>

        <div class="mt-8">
          <a
            href={event.meetup_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-6 py-3 text-base font-semibold text-brand-950 transition hover:bg-accent-400"
          >
            Register on Meetup
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
