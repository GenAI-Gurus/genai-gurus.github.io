---
import event from "@/data/upcoming_event.json";

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZoneName: "short",
  });
}
---

<section id="upcoming" class="relative bg-brand-900 py-20 md:py-28">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand-950 via-transparent to-brand-950 opacity-40"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Next Event
    </div>
    <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      Don&rsquo;t miss our upcoming session
    </h2>

    <div class="group mt-10 overflow-hidden rounded-2xl border border-brand-700/60 bg-gradient-to-br from-brand-800/60 to-brand-800/30 shadow-2xl shadow-black/20 transition-all hover:border-brand-600/80 md:flex">
      {
        event.image && (
          <div class="relative flex-shrink-0 overflow-hidden md:w-1/2">
            <img
              src={event.image}
              alt={event.title}
              class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-105 md:h-full"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-brand-800/30"></div>
          </div>
        )
      }

      <div class="flex flex-1 flex-col justify-center p-8 md:p-10">
        <div class="inline-flex items-center gap-2 self-start rounded-full bg-accent-500/10 px-3 py-1 text-sm font-medium text-accent-400">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
          </svg>
          {formatDate(event.date)}
        </div>

        <h3 class="mt-4 font-display text-2xl font-bold leading-snug text-white md:text-3xl">
          {event.title}
        </h3>

        {
          event.speaker_name && (
            <div class="mt-4 flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-500/10">
                <svg class="h-4 w-4 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                </svg>
              </div>
              <p class="text-base text-brand-200">
                <span class="font-semibold text-white">{event.speaker_name}</span>
                {event.speaker_role && (
                  <span class="text-brand-300"> &middot; {event.speaker_role}</span>
                )}
              </p>
            </div>
          )
        }

        <p class="mt-4 leading-relaxed text-brand-300">
          {event.summary}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href={event.meetup_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group/btn inline-flex items-center gap-2 rounded-xl bg-accent-500 px-6 py-3 text-base font-semibold text-brand-950 shadow-lg shadow-accent-500/20 transition-all hover:bg-accent-400 hover:shadow-accent-500/30 hover:-translate-y-0.5"
          >
            Register on Meetup
            <svg class="h-4 w-4 transition-transform group-hover/btn:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          {
            event.rsvp_count && (
              <span class="inline-flex items-center gap-1.5 text-sm text-brand-300">
                <svg class="h-4 w-4 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                </svg>
                {event.rsvp_count}+ registered
              </span>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
