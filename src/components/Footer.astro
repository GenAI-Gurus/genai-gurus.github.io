---
import site from "@/data/site.json";
const year = new Date().getFullYear();
---

<footer class="relative border-t border-brand-800/80 bg-brand-950 py-16">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-500/20 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-10 md:grid-cols-4">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="group inline-flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-accent-500/10 transition group-hover:bg-accent-500/15">
            <svg width="22" height="22" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="14" stroke="#F6B141" stroke-width="2"/>
              <circle cx="10.5" cy="12.5" r="2.2" fill="#F6B141"/>
              <circle cx="21.5" cy="12.5" r="2.2" fill="#F6B141"/>
              <circle cx="16" cy="20.5" r="2.2" fill="#F6B141"/>
              <line x1="10.5" y1="12.5" x2="21.5" y2="12.5" stroke="#F6B141" stroke-width="1.4" stroke-linecap="round"/>
              <line x1="10.5" y1="12.5" x2="16" y2="20.5" stroke="#F6B141" stroke-width="1.4" stroke-linecap="round"/>
              <line x1="21.5" y1="12.5" x2="16" y2="20.5" stroke="#F6B141" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-display text-lg font-bold tracking-tight text-white">
            GenAI <span class="text-accent-500">Gurus</span>
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-brand-400">
          A global community for builders, researchers, and leaders exploring applied Generative AI.
        </p>

        <!-- Social icons -->
        <div class="mt-6 flex gap-2">
          <a
            href={site.links.meetup}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg text-brand-400 transition hover:bg-white/5 hover:text-accent-500"
            aria-label="Meetup"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 14.07a2.97 2.97 0 0 0-.85-1.07 2.97 2.97 0 0 0 .6-1.72c0-1.6-1.28-2.9-2.87-2.9a2.88 2.88 0 0 0-2.71 1.93 2.88 2.88 0 0 0-2.56-1.56c-1.3 0-2.4.86-2.75 2.05a2.88 2.88 0 0 0-2.34-1.2c-1.59 0-2.88 1.3-2.88 2.9 0 .54.15 1.05.41 1.48A2.9 2.9 0 0 0 2 16.86c0 1.3.86 2.4 2.04 2.76a2.87 2.87 0 0 0 4.98.65 2.87 2.87 0 0 0 4.17-.42c.57.67 1.42 1.1 2.37 1.1a2.88 2.88 0 0 0 2.74-3.76c.7-.5 1.17-1.32 1.17-2.25 0-.33-.06-.65-.17-.94l.01.07z"/></svg>
          </a>
          <a
            href={site.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg text-brand-400 transition hover:bg-white/5 hover:text-accent-500"
            aria-label="LinkedIn"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a
            href={site.links.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg text-brand-400 transition hover:bg-white/5 hover:text-accent-500"
            aria-label="YouTube"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a
            href={`mailto:${site.links.email}`}
            class="flex h-9 w-9 items-center justify-center rounded-lg text-brand-400 transition hover:bg-white/5 hover:text-accent-500"
            aria-label="Email"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-brand-200">Navigate</h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href="#upcoming" class="text-brand-400 transition hover:text-white">Next Event</a></li>
          <li><a href="#talks" class="text-brand-400 transition hover:text-white">Featured Talks</a></li>
          <li><a href="#team" class="text-brand-400 transition hover:text-white">Core Team</a></li>
          <li><a href="#about" class="text-brand-400 transition hover:text-white">About Us</a></li>
          <li><a href="/leaderboard" class="text-brand-400 transition hover:text-white">Leaderboard</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-brand-200">Community</h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              href={site.links.meetup}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-400 transition hover:text-white">Meetup Group</a>
          </li>
          <li>
            <a
              href={site.links.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-400 transition hover:text-white">LinkedIn Page</a>
          </li>
          <li>
            <a
              href={site.links.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-400 transition hover:text-white">YouTube Channel</a>
          </li>
        </ul>
      </div>

      <!-- Engage -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-brand-200">Engage</h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              href={site.links.speak_form}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-400 transition hover:text-white">Apply to speak</a>
          </li>
          <li>
            <a
              href={site.links.partner_form}
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-400 transition hover:text-white">Partner with us</a>
          </li>
          <li>
            <a
              href={`mailto:${site.links.email}`}
              class="text-brand-400 transition hover:text-white">Contact</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-brand-800/60 pt-8 text-xs text-brand-500 sm:flex-row">
      <p>&copy; {year} GenAI Gurus. All rights reserved.</p>
      <p>Built with passion for the AI community.</p>
    </div>
  </div>
</footer>
