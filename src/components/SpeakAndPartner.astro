---
import site from "@/data/site.json";
---

<section id="engage" class="relative py-20 md:py-28">
  <div class="pointer-events-none absolute right-0 bottom-0 h-96 w-96 rounded-full bg-accent-500/3 blur-3xl"></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-accent-500">
      Get Involved
    </div>
    <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      Speak or partner with us
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-brand-300">
      We're always looking for great speakers and meaningful partnerships. Whether you want to share
      your expertise or collaborate with the community, we'd love to hear from you.
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <div class="group rounded-2xl border border-brand-700/50 bg-gradient-to-b from-brand-800/40 to-brand-800/20 p-8 transition-all hover:border-accent-500/20 hover:shadow-xl hover:shadow-black/20 hover:-translate-y-1">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-500/10 transition group-hover:bg-accent-500/15">
          <svg class="h-7 w-7 text-accent-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
          </svg>
        </div>
        <h3 class="font-display text-xl font-semibold text-white">Apply to speak</h3>
        <p class="mt-3 text-sm leading-relaxed text-brand-300">
          Share your experience with a technical and strategic AI audience. We feature practitioners,
          researchers, and leaders.
        </p>
        <a
          href={site.links.speak_form}
          target="_blank"
          rel="noopener noreferrer"
          class="group/btn mt-6 inline-flex items-center gap-2 rounded-xl bg-accent-500 px-5 py-2.5 text-sm font-semibold text-brand-950 shadow-lg shadow-accent-500/20 transition-all hover:bg-accent-400 hover:shadow-accent-500/30 hover:-translate-y-0.5"
        >
          Submit a talk proposal
          <svg class="h-4 w-4 transition-transform group-hover/btn:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>

      <div class="group rounded-2xl border border-brand-700/50 bg-gradient-to-b from-brand-800/40 to-brand-800/20 p-8 transition-all hover:border-accent-500/20 hover:shadow-xl hover:shadow-black/20 hover:-translate-y-1">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-500/10 transition group-hover:bg-accent-500/15">
          <svg class="h-7 w-7 text-accent-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
        </div>
        <h3 class="font-display text-xl font-semibold text-white">Partner with us</h3>
        <p class="mt-3 text-sm leading-relaxed text-brand-300">
          Sponsors, enterprise collaborators, startups, and recruiters — explore ways to engage with
          a growing AI community.
        </p>
        <a
          href={site.links.partner_form}
          target="_blank"
          rel="noopener noreferrer"
          class="group/btn mt-6 inline-flex items-center gap-2 rounded-xl border border-brand-600/60 px-5 py-2.5 text-sm font-medium text-brand-200 transition-all hover:border-brand-400 hover:text-white hover:-translate-y-0.5"
        >
          Explore partnerships
          <svg class="h-4 w-4 transition-transform group-hover/btn:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
